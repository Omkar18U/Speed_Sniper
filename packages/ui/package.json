{
  "name": "@speed-sniper/ui",
  "version": "0.0.1",
  "private": true,
  "nx": {
    "targets": {
      "build": {
        "executor": "nx:run-commands",
        "options": {
          "commands": [
            "webpack --node-env production"
          ],
          "cwd": "packages/ui"
        }
      },
      "serve-static": {
        "executor": "@nx/web:file-server",
        "dependsOn": [
          "build"
        ],
        "options": {
          "buildTarget": "@speed-sniper/ui:build",
          "spa": true
        }
      }
    }
  }
}
